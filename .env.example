DATABASE_URL=jdbc:postgresql://localhost:5432/cinema
DATABASE_USER=REDACTED
DATABASE_PASSWORD=REDACTED
DATABASE_NAME=cinema

JWT_SECRET_KEY=REDACTED

SECURITY_COOKIE_SECURE=true
SECURITY_COOKIE_SAME_SITE=LAX

SECURITY_MAX_ATTEMPTS=5
SECURITY_WEBSITE_DOMAIN=http://localhost:4200
SECURITY_CSRF_ENABLED=true
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:4200

BOOTSTRAP_OWNER_USERNAME=admin
BOOTSTRAP_OWNER_PASSWORD=Redacted1!
BOOTSTRAP_OWNER_EMAIL=owner@example.com
BOOTSTRAP_OWNER_FIRST_NAME=Ion
BOOTSTRAP_OWNER_LAST_NAME=Popescu
BOOTSTRAP_OWNER_PHONE_NUMBER=0777777777

TMDB_API_KEY=REDACTED

# --- Microservices stack (docker-compose.microservices.yml) ---
USER_DB_NAME=user_db
CATALOG_DB_NAME=catalog_db
BOOKING_DB_NAME=booking_db
GATEWAY_RATE_LIMIT_REPLENISH=50
GATEWAY_RATE_LIMIT_BURST=100

# Symmetric key the Spring Cloud Config server uses to decrypt the {cipher}
# values it serves (e.g. JWT_SECRET_KEY). Must match the key used to produce
# those ciphertexts via the config server's /encrypt endpoint.
# This sample key matches the committed {cipher} JWT value so the stack runs
# out-of-the-box; rotate it (and re-encrypt the secrets) for any real use.
# (The microservices receive JWT/TMDB decrypted from the config server; the
#  monolith stack still reads JWT_SECRET_KEY / TMDB_API_KEY above directly.)
ENCRYPT_KEY=Hn7Qd2sKpV9xL4mZ8rT3wB6yN1jF5gC0aE2uI4oP7kR9tW3